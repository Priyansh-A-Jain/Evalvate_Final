# -----------------------------
# Backend Environment Template
# -----------------------------
# Copy to backend/.env and fill in values.

# ─── MongoDB ───────────────────────────────────────────
# Local dev: mongodb://127.0.0.1:27017
# Atlas M0 (free): https://cloud.mongodb.com -> connect -> URI
MONGO_URI=mongodb://127.0.0.1:27017

# ─── Auth ──────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret
# Google OAuth: console.cloud.google.com -> Credentials -> OAuth 2.0 Client
# Redirect URI must be: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
POST_LOGIN_REDIRECT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
RESEND_API_KEY=
AUTH_FROM_EMAIL=Evalvate <onboarding@resend.dev>

# ─── LLM (OpenRouter -> Gemini) ────────────────────────
# https://openrouter.ai -> API Keys (free credits on signup)
OPENROUTER_API_KEY=replace-with-openrouter-api-key
INTERVIEW_AGENT_MODEL=google/gemini-2.5-flash-lite
INTERVIEW_AGENT_BASE_URL=https://openrouter.ai/api/v1
INTERVIEW_AGENT_TIMEOUT_SECONDS=90
INTERVIEW_AGENT_TEMPERATURE=0.35
INTERVIEW_AGENT_MAX_OUTPUT_TOKENS=1200
INTERVIEW_AGENT_REALTIME_MAX_OUTPUT_TOKENS=320
INTERVIEW_AGENT_MAX_RETRIES=2
INTERVIEW_AGENT_HISTORY_LIMIT=5
OPENROUTER_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=evalvate-local

# ─── Speech (Deepgram) ─────────────────────────────────
# https://deepgram.com -> API Keys ($200 free credits)
DEEPGRAM_API_KEY=replace-with-deepgram-api-key
INTERVIEW_TTS_MODEL=aura-2-thalia-en
MEETING_STT_MODEL=nova-2

# ─── Hume AI (vocal prosody, optional) ─────────────────
# https://hume.ai -> API Keys (100 min/month free)
HUME_API_KEY=

# ─── Simli (AI avatar, key also needed on frontend) ────
# https://simli.ai -> API key (free tier)
SIMLI_API_KEY=

# ─── Demo mode (one-click investor demo, no Google login)
DEMO_MODE=false

# ─── Observability (optional) ──────────────────────────
SENTRY_DSN=

# ─── App config ────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
INTERVIEW_MAX_QUESTIONS=5
INTERVIEW_REALTIME_ROLE=Full Stack Engineer
INTERVIEW_REALTIME_DIFFICULTY=medium
INTERVIEW_REALTIME_PERSONA=mentor
GROUP_INTERVIEW_TOTAL_TURNS=9
LOG_LEVEL=INFO
ENVIRONMENT=development
